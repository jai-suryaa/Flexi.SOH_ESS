    device_id IS NOT NULL
    AND ts IS NOT NULL
    AND current IS NOT NULL
    AND soc IS NOT NULL
    AND q_delta IS NOT NULL
    AND q_throughput IS NOT NULL


    AND ts > (SELECT MAX(ts) FROM "dev"."main"."inter_battery_variable_mapping")

    );
  
  
  
